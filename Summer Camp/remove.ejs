<!DOCTYPE html>
<html lang="en">

    <head>

        <meta charset="UTF-8"/>
        <title>Admin Remove</title>
    </head>

    <body>

        <h1>Removing All Applicants</h1>

        <form id="removeForm" action="/remove" method="post">
            <input type="button" id="removeBtn" value="Remove all applicants"/>
        </form>
        <hr/>

        <a href="/">HOME</a>
        <script>

            document.getElementById("removeBtn").onclick = function() {
                
                const confirmed = confirm("Are you sure you want to remove all applications?");
                
                if (confirmed) {
                    
                    document.getElementById("removeForm").submit();
                }
            };
        </script>
    </body>
</html>