<!DOCTYPE html>
<html lang="en">

    <head>

        <meta charset="UTF-8"/>
        <title>Application</title>
    </head>

    <body>

        <h1>Application</h1>
        
        <form id="applyForm" action="/apply" method="post">
            <fieldset>
                
                <label><strong>Name:</strong></label><input type="text" name="name" required/>
                <label><strong>Email Address:</strong></label><input type="text" name="email" required/>
                <br/><br/>

                <label><strong>GPA:</strong></label><input type="text" name="gpa" required/>
                <br/><br/>

                <label><strong>Background Information:</strong></label><br/>
                <textarea name="info" rows="5" cols="60"></textarea>
            </fieldset>
            <br/>

            <input type="reset" value="Reset"/>
            <input type="button" id="submitBtn" value="Submit Application"/>
        </form>
        <hr/>

        <a href="/">HOME</a>
        <script>
            
            document.getElementById("submitBtn").onclick = function() {
                
                const confirmed = confirm("Are you sure you want to submit your application?\nYou will not be able to change your information once submitted.");
                
                if (confirmed) {
                    
                    document.getElementById("applyForm").submit();
                }
            };
        </script>
    </body>
</html>